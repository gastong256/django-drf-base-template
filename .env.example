# Copy to .env and fill in values before running locally.
# Never commit .env to version control.

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=__DJANGO_SECRET_KEY__
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/__PROJECT_SLUG__

# ── Redis (optional) ──────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Server ────────────────────────────────────────────────────────────────────
PORT=__PORT__

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=__SERVICE_NAME__

# ── API Security ──────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
RATE_LIMIT_ANON=60/minute
RATE_LIMIT_USER=300/minute

# ── Reverse Proxy / HTTPS (prod) ─────────────────────────────────────────────
SECURE_PROXY_SSL_HEADER_NAME=HTTP_X_FORWARDED_PROTO
SECURE_PROXY_SSL_HEADER_VALUE=https
USE_X_FORWARDED_HOST=true
# CSRF_TRUSTED_ORIGINS=https://api.example.com,https://admin.example.com
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_HTTPONLY=true
CSRF_COOKIE_SAMESITE=Lax

# ── CORS (optional) ───────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=false
# CORS_ALLOWED_ORIGINS=http://localhost:3000
